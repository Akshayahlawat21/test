# ─── Server ───
NODE_ENV=production
PORT=5000

# ─── Database ───
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/golf-charity?retryWrites=true&w=majority

# ─── JWT ───
JWT_ACCESS_SECRET=your-strong-random-access-secret-here
JWT_REFRESH_SECRET=your-strong-random-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# ─── Frontend URL (for CORS & emails) ───
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (SMTP) ───
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ─── Cloudinary (optional, for charity images) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
